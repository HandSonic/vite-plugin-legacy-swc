{
  "name": "vite-plugin-legacy-swc",
  "version": "2.0.2",
  "description": "Provides legacy browsers support for the production build with SWC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint --fix './**/*.{js,ts}'",
    "lint:ci": "eslint --max-warnings 0 './**/*.{js,ts}'",
    "prepack": "tsdown",
    "release": "release-it",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyanSalt/vite-plugin-legacy-swc.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "legacy",
    "swc"
  ],
  "author": "CyanSalt",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CyanSalt/vite-plugin-legacy-swc/issues"
  },
  "homepage": "https://github.com/CyanSalt/vite-plugin-legacy-swc#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "dependencies": {
    "@swc/core": "^1.15.33",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "core-js": "^3.49.0",
    "magic-string": "^0.30.21",
    "regenerator-runtime": "^0.14.1",
    "systemjs": "^6.15.1"
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.6.0",
    "@cyansalt/tsconfig": "^3.0.2",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^24.12.3",
    "acorn": "^8.16.0",
    "eslint": "^10.3.0",
    "picocolors": "^1.1.1",
    "release-it": "^20.0.1",
    "rollup": "^4.60.3",
    "terser": "^5.47.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  }
}
